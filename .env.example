ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL=claude-sonnet-4-5-20251022

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# One of: anthropic | gemini | openai | mistral
LLM_PROVIDER=anthropic

PORT=8000
ENVIRONMENT=development

# On Railway, set ENVIRONMENT=production and PORT is injected automatically.
# Only the API key matching LLM_PROVIDER is required — all other variables have sensible defaults.

# Epic FHIR Sandbox OAuth (SMART on FHIR — Backend Systems / JWT assertion)
# Register at: https://fhir.epic.com/Developer/Apps
# Generate keys: python scripts/generate_epic_keys.py
# Leave blank to disable — existing behaviour unchanged.
EPIC_CLIENT_ID=
EPIC_PRIVATE_KEY=    # single-line PEM with \n separators (from generate_epic_keys.py)
EPIC_KID=lablens-1
# EPIC_CLIENT_SECRET= deprecated — JWT assertion replaces it, ignored if present
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
